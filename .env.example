# Compose project
COMPOSE_PROJECT_NAME=local-rag
GENERIC_TIMEZONE=Asia/Kuala_Lumpur

# Pinned container versions
N8N_VERSION=2.28.0
POSTGRES_VERSION=17.10-bookworm
REDIS_VERSION=7.4.9-bookworm
MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
MINIO_MC_VERSION=RELEASE.2025-08-13T08-35-41Z
QDRANT_VERSION=v1.18.2-unprivileged
OLLAMA_VERSION=0.30.10
DOCLING_VERSION=v1.25.0
CADDY_VERSION=2.11.4

# Local ports (bound to 127.0.0.1 by compose.dev.yml)
CADDY_HTTP_PORT=8080
N8N_PORT=5678
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
QDRANT_HTTP_PORT=6333
OLLAMA_PORT=11434
DOCLING_PORT=5001

# Production routing
APP_DOMAIN=app.example.com
N8N_DOMAIN=n8n.example.com
TLS_EMAIL=admin@example.com

# PostgreSQL administrator and application databases
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=REPLACE_WITH_RANDOM_POSTGRES_ADMIN_PASSWORD
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=REPLACE_WITH_RANDOM_N8N_DB_PASSWORD
RAG_DB_NAME=rag
RAG_DB_USER=rag
RAG_DB_PASSWORD=REPLACE_WITH_RANDOM_RAG_DB_PASSWORD

# Redis queue
REDIS_PASSWORD=REPLACE_WITH_RANDOM_REDIS_PASSWORD

# n8n
N8N_ENCRYPTION_KEY=REPLACE_WITH_RANDOM_N8N_ENCRYPTION_KEY
N8N_WORKER_CONCURRENCY=1
N8N_EXECUTIONS_MAX_AGE_HOURS=168
N8N_EXECUTIONS_PRUNE_MAX_COUNT=10000

# MinIO
MINIO_ROOT_USER=ragadmin
MINIO_ROOT_PASSWORD=REPLACE_WITH_RANDOM_MINIO_ROOT_PASSWORD
MINIO_DOCUMENTS_BUCKET=rag-documents

# Qdrant
QDRANT_API_KEY=REPLACE_WITH_RANDOM_QDRANT_API_KEY
QDRANT_COLLECTION=rag_chunks

# RAG ingestion
RAG_DEFAULT_KB_ID=00000000-0000-4000-8000-000000000001
RAG_MAX_UPLOAD_BYTES=26214400

# Ollama bootstrap defaults. Model names are intentionally configurable.
OLLAMA_CHAT_MODEL=qwen3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Resource limits suitable for the 16 GB development laptop.
POSTGRES_MEMORY_LIMIT=768m
REDIS_MEMORY_LIMIT=256m
N8N_MAIN_MEMORY_LIMIT=1g
N8N_WORKER_MEMORY_LIMIT=2g
MINIO_MEMORY_LIMIT=768m
QDRANT_MEMORY_LIMIT=1536m
OLLAMA_MEMORY_LIMIT=5g
DOCLING_MEMORY_LIMIT=4g
CADDY_MEMORY_LIMIT=256m
